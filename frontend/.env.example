# ===========================================
# Frontend .env.example — Vite app configuration
#
# COPY to .env and fill in your values:
#   cp .env.example .env
#
# Only VITE_ prefixed vars are exposed to browser via import.meta.env
#
# Port map (local dev):
#   Vite dev server → 5173
#   Backend API     → 8000 (proxied via vite.config.ts)
#   Supabase API    → 54321
# ===========================================

# --- App ---
VITE_APP_TITLE=RAG Business Wiki

# --- Supabase ---
# Local: http://127.0.0.1:54321 | Remote: https://<project-ref>.supabase.co
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- API ---
# Vite proxies /api → http://localhost:8000 automatically (see vite.config.ts)
# Only set this if backend runs on a different host/port:
# VITE_API_BASE_URL=http://localhost:8000
