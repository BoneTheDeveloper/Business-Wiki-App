# ===========================================
# Frontend Environment Variables
# Copy this to .env and fill in your values
# ===========================================

# --- Supabase Auth ---
# Local: http://127.0.0.1:54321 | Remote: https://your-project.supabase.co
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- API ---
# Vite proxies /api to backend automatically (see vite.config.ts)
# Only set this if backend runs on a different host/port
# VITE_API_BASE_URL=http://localhost:8000
