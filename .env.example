# ===========================================
# Root .env.example — Single source of truth
#
# COPY to .env.local and fill in your values:
#   cp .env.example .env.local
#
# This file is the ONLY .env you need to maintain.
# Docker Compose and Supabase CLI read from here.
# Backend and frontend have their own .env.local for local dev
# (outside Docker), but values should match this file.
#
# .env.local files are gitignored — only .env.example is committed.
# ===========================================

# --- Service Ports (used by docker-compose with fallback defaults) ---
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
BACKEND_PORT=8000
FRONTEND_PORT=5173
CHAINLIT_PORT=8001
SUPABASE_DB_PORT=54322

# --- Supabase ---
# Local: `supabase start` → API=54321, DB=54322
# Remote: https://<project-ref>.supabase.co
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Google Gemini (embeddings + chat) ---
GOOGLE_API_KEY=your-google-api-key

# --- Google OAuth (Supabase Auth provider) ---
# Get from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://127.0.0.1:54321/auth/v1/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- MinIO (Object Storage credentials) ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
