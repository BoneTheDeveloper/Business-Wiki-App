# ===========================================
# ROOT .env — Docker Compose + shared variables
#
# This file is used by:
#   - `docker compose up` for ${VAR:-default} substitution
#   - Shared Supabase credentials for all services
#
# For running backend/frontend locally (outside Docker), use:
#   - backend/.env    → FastAPI app config (DB, Supabase, MinIO, Gemini)
#   - frontend/.env   → Vite app config (app title, Supabase)
# ===========================================

# --- Supabase ---
# Local: supabase start → uses Docker local stack (port 54322 for DB, 54321 for API)
# Remote: your Supabase project credentials
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Google OAuth (for Supabase Auth) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Gemini (passed to backend + celery containers) ---
GOOGLE_API_KEY=your-google-api-key

# --- MinIO (creates MinIO container credentials) ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
