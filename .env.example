# ===========================================
# Root .env.example — Docker Compose + shared variables
#
# COPY to .env and fill in your values:
#   cp .env.example .env
#
# .env files are gitignored — only .env.example is committed.
#
# Structure:
#   .env              → Docker Compose variable substitution
#   backend/.env      → FastAPI app (Supabase, DB, Redis, MinIO, Gemini)
#   frontend/.env     → Vite dev server (VITE_ prefixed vars only)
# ===========================================

# --- Service Ports (used by docker-compose with fallback defaults) ---
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
BACKEND_PORT=8000
FRONTEND_PORT=3000
SUPABASE_DB_PORT=54322

# --- Supabase ---
# Local: `supabase start` → API=54321, DB=54322
# Remote: https://<project-ref>.supabase.co
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Google Gemini (embeddings + chat) ---
GOOGLE_API_KEY=your-google-api-key

# --- Google OAuth (Supabase Auth provider) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- MinIO (Object Storage credentials) ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
