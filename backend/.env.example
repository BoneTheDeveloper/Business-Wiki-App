# ===========================================
# Backend Environment Variables
# Copy this to .env and fill in your values
# ===========================================

# --- Supabase ---
# Local dev (supabase start): http://127.0.0.1:54321
# Remote: https://<project-ref>.supabase.co
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Database (Supabase PostgreSQL) ---
# Local Supabase stack (supabase start):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres
# Remote Supabase (direct connection):
# DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-region.pooler.supabase.com:5432/postgres

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- MinIO (Object Storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_SECURE=false

# --- Google Gemini (RAG: embeddings + chat) ---
GOOGLE_API_KEY=your-google-api-key
